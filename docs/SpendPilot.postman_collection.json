            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Tester Updated\",\n  \"mobile\": \"+15551234567\",\n  \"subscriptionPlan\": \"pro\"\n}" },
            "url": "{{baseUrl}}/api/profile"
          }
        },
        {
          "name": "Update email",
          "request": {
            "method": "PATCH",
            "header": [
