{
  "info": {
    "name": "SpendPilot Backend",
    "_postman_id": "spendpilot-backend-collection",
    "description": "Manual testing collection for the SpendPilot backend. Variables are stored at the collection level and auto-populated by test scripts (token, adminToken, crmToken, cardId, ticketId, totpSecret, totpCode). Run requests roughly top-to-bottom. Start the server with SEED_DEMO_DATA=true so the admin and demo data exist.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "userEmail", "value": "tester@spendpilot.test" },
    { "key": "userPassword", "value": "secret123" },
    { "key": "adminEmail", "value": "admin@spendpilot.app" },
    { "key": "adminPassword", "value": "Admin1234!" },
    { "key": "token", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "crmToken", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "cardId", "value": "" },
    { "key": "ticketId", "value": "" },
    { "key": "totpSecret", "value": "" },
    { "key": "totpCode", "value": "" },
    { "key": "publicToken", "value": "demo-public-token" },
    { "key": "cronSecret", "value": "test-cron-secret" }
  ],
  "item": [
    {
      "name": "1. Health",
      "item": [
        {
          "name": "Health",
          "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/api/health" }
        },
        {
          "name": "Readiness",
          "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/api/health/ready" }
        }
      ]
    },
    {
      "name": "2. Public Content",
      "item": [
        { "name": "Terms", "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/api/legal/terms" } },
        { "name": "Privacy", "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/api/legal/privacy" } },
        { "name": "Help", "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/api/help" } }
      ]
    },
    {
      "name": "3. Auth",
      "item": [
        {
          "name": "Signup",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json();",
                  "if (pm.response.code === 201 && j.token) {",
                  "  pm.collectionVariables.set('token', j.token);",
                  "  pm.collectionVariables.set('userId', j.user.id);",
                  "  pm.test('signup 201 + token', () => pm.expect(j.token).to.be.a('string'));",
                  "} else if (pm.response.code === 409) {",
                  "  pm.test('already exists - run Login instead', () => true);",
                  "} else {",
                  "  pm.test('signup unexpected', () => pm.expect(pm.response.code).to.be.oneOf([201,409]));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Tester\",\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}" },
            "url": "{{baseUrl}}/api/auth/signup"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.token) { pm.collectionVariables.set('token', j.token); pm.collectionVariables.set('userId', j.user.id); }",
                  "pm.test('login 200 + token', () => pm.expect(pm.response.code).to.eql(200) && pm.expect(j.token).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}" },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Login (wrong password) -> 401",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"wrong\"\n}" },
            "url": "{{baseUrl}}/api/auth/login"
          }
        }
      ]
    },
    {
      "name": "4. Profile",
