    {
      "name": "11. Admin CRM (TOTP-gated)",
      "item": [
        {
          "name": "Admin login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.token) pm.collectionVariables.set('adminToken', j.token);",
                  "pm.test('admin login 200', () => pm.expect(pm.response.code).to.eql(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}" },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "TOTP status",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }], "url": "{{baseUrl}}/api/admin/totp/status" }
        },
        {
          "name": "TOTP setup (saves secret)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.secret) pm.collectionVariables.set('totpSecret', j.secret);",
                  "pm.test('setup ok + secret saved', () => pm.expect(j.secret).to.be.a('string'));",
                  "console.log('otpauthUrl:', j.otpauthUrl);"
                ]
              }
            }
          ],
          "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }], "url": "{{baseUrl}}/api/admin/totp/setup" }
        },
        {
          "name": "TOTP enable (auto-generates code)",
          "event": [
            { "listen": "prerequest", "script": { "exec": [
              "// Generate a TOTP code from the saved base32 secret using CryptoJS.",
              "const CryptoJS = require('crypto-js');",
              "const secret = pm.collectionVariables.get('totpSecret');",
              "function b32hex(b32){const A='ABCDEFGHIJKLMNOPQRSTUVWXYZ234567';let bits='',hex='';b32=(b32||'').replace(/=+$/,'').toUpperCase();for(const c of b32){const v=A.indexOf(c);if(v<0)continue;bits+=v.toString(2).padStart(5,'0');}for(let i=0;i+4<=bits.length;i+=4){hex+=parseInt(bits.substr(i,4),2).toString(16);}return hex;}",
              "function totp(sec){const key=CryptoJS.enc.Hex.parse(b32hex(sec));let t=Math.floor(Math.floor(Date.now()/1000)/30).toString(16);while(t.length<16)t='0'+t;const hmac=CryptoJS.HmacSHA1(CryptoJS.enc.Hex.parse(t),key).toString(CryptoJS.enc.Hex);const off=parseInt(hmac.substr(hmac.length-1),16);const code=(parseInt(hmac.substr(off*2,8),16)&0x7fffffff)+'';return code.substr(code.length-6,6);}",
              "pm.collectionVariables.set('totpCode', totp(secret));"
            ] } }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"{{totpCode}}\"\n}" },
            "url": "{{baseUrl}}/api/admin/totp/enable"
          }
        },
        {
          "name": "TOTP verify -> crmToken (auto-generates code)",
          "event": [
            { "listen": "prerequest", "script": { "exec": [
              "const CryptoJS = require('crypto-js');",
              "const secret = pm.collectionVariables.get('totpSecret');",
              "function b32hex(b32){const A='ABCDEFGHIJKLMNOPQRSTUVWXYZ234567';let bits='',hex='';b32=(b32||'').replace(/=+$/,'').toUpperCase();for(const c of b32){const v=A.indexOf(c);if(v<0)continue;bits+=v.toString(2).padStart(5,'0');}for(let i=0;i+4<=bits.length;i+=4){hex+=parseInt(bits.substr(i,4),2).toString(16);}return hex;}",
              "function totp(sec){const key=CryptoJS.enc.Hex.parse(b32hex(sec));let t=Math.floor(Math.floor(Date.now()/1000)/30).toString(16);while(t.length<16)t='0'+t;const hmac=CryptoJS.HmacSHA1(CryptoJS.enc.Hex.parse(t),key).toString(CryptoJS.enc.Hex);const off=parseInt(hmac.substr(hmac.length-1),16);const code=(parseInt(hmac.substr(off*2,8),16)&0x7fffffff)+'';return code.substr(code.length-6,6);}",
              "pm.collectionVariables.set('totpCode', totp(secret));"
            ] } },
            { "listen": "test", "script": { "exec": [
              "const j = pm.response.json();",
              "if (j.crmToken) pm.collectionVariables.set('crmToken', j.crmToken);",
              "pm.test('got crmToken', () => pm.expect(j.crmToken).to.be.a('string'));"
            ] } }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"{{totpCode}}\"\n}" },
            "url": "{{baseUrl}}/api/admin/totp/verify"
          }
        },
        {
          "name": "CRM: list users (needs crmToken)",
          "event": [
            { "listen": "test", "script": { "exec": [
              "const j = pm.response.json();",
              "if (j.users && j.users.length) pm.collectionVariables.set('userId', j.users[j.users.length-1].id);"
            ] } }
          ],
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{crmToken}}" }], "url": "{{baseUrl}}/api/admin/users" }
        },
        {
          "name": "CRM: list users with NORMAL token -> 401",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }], "url": "{{baseUrl}}/api/admin/users" }
        },
        {
          "name": "CRM: get user detail",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{crmToken}}" }], "url": "{{baseUrl}}/api/admin/users/{{userId}}" }
        },
        {
          "name": "CRM: edit user",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{crmToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"subscriptionPlan\": \"enterprise\"\n}" },
            "url": "{{baseUrl}}/api/admin/users/{{userId}}"
          }
        },
        {
          "name": "CRM: list tickets",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{crmToken}}" }], "url": "{{baseUrl}}/api/admin/tickets" }
        },
        {
          "name": "CRM: reply + set status (relay, admin side)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{crmToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"reply\": \"Thanks for reaching out - which bank are you connecting?\",\n  \"status\": \"pending\"\n}" },
            "url": "{{baseUrl}}/api/admin/tickets/{{ticketId}}"
          }
        },
        {
          "name": "CRM: delete user",
          "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{crmToken}}" }], "url": "{{baseUrl}}/api/admin/users/{{userId}}" }
        }
      ]
    },
    {
      "name": "12. Alerts & Progress",
      "item": [
        {
          "name": "Alerts (due / utilization / payday)",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/api/alerts" }
        },
        {
          "name": "Progress (history, milestones, interest saved)",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/api/progress" }
        }
      ]
    },
    {
      "name": "13. Cron (CRON_SECRET)",
      "item": [
        {
          "name": "Card sync (daily)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{cronSecret}}" }],
            "url": "{{baseUrl}}/api/cron/card-sync"
          }
        },
        {
          "name": "Alerts digest (daily email)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{cronSecret}}" }],
            "url": "{{baseUrl}}/api/cron/alerts-digest"
          }
        }
      ]
    }
  ]
}
